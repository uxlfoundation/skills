{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uxlfoundation.org/schemas/uxl-skill-evals.schema.json",
  "title": "UXL Skill Evals",
  "type": "object",
  "required": ["skill_name", "evals"],
  "properties": {
    "skill_name": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "evals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "prompt", "expected_output", "checks"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "prompt": { "type": "string", "minLength": 1 },
          "expected_output": { "type": "string", "minLength": 1 },
          "checks": {
            "type": "object",
            "required": ["must_include"],
            "properties": {
              "must_include": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "must_not_include": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
