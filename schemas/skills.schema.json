{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uxlfoundation.org/schemas/uxl-skills-catalog.schema.json",
  "title": "UXL Skills Catalog Manifest",
  "type": "object",
  "required": ["schema_version", "catalog_status", "canonical_instructions", "skills"],
  "properties": {
    "schema_version": { "const": "1" },
    "catalog_status": { "enum": ["incubating", "pilot", "released"] },
    "canonical_instructions": { "const": "AGENTS.md" },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "status",
          "owner_project",
          "owner_repo",
          "catalog_path",
          "skill_card",
          "source_of_truth_target",
          "maintainer_review"
        ],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "status": { "enum": ["incubating", "pilot", "reviewed", "project-owned"] },
          "owner_project": { "type": "string" },
          "owner_repo": { "type": "string", "format": "uri" },
          "catalog_path": { "type": "string" },
          "skill_card": { "type": "string" },
          "source_of_truth_target": { "type": "string" },
          "maintainer_review": { "type": "string" },
          "last_source_verification": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
